rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "none";
    }
    function isSuperAdmin() { return myRole() == "admin"; }
    function isStaff()      { return myRole() == "admin" || myRole() == "faculty"; }
    function isSelf(uid)    { return signedIn() && request.auth.uid == uid; }

    // ---------- users ----------
    match /users/{uid} {
      // staff need to read the student list (for exam assignment); a user can read self
      allow read: if isSelf(uid) || isStaff();
      // ONLY super-admins create/promote/demote/remove accounts.
      // The very first admin must be created from the Firebase console (see README).
      allow create, update, delete: if isSuperAdmin();
    }

    // ---------- questions ----------
    match /questions/{questionId} {
      allow read: if signedIn();                 // students load questions during the exam
      // staff create their own; only the owner or a super-admin can edit/delete
      allow create: if isStaff() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSuperAdmin() ||
        (isStaff() && resource.data.createdBy == request.auth.uid);
    }

    // ---------- exams ----------
    match /exams/{examId} {
      allow read: if signedIn();
      allow create: if isStaff() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSuperAdmin() ||
        (isStaff() && resource.data.createdBy == request.auth.uid);
    }

    // ---------- attempts ----------
    match /attempts/{attemptId} {
      // signed-in users may read attempts (needed for client-side rank/percentile).
      // Tighten to own + staff if score privacy matters more than client percentile.
      allow read: if signedIn();
      // a student creates/updates only their own attempt
      allow create: if signedIn() &&
        request.resource.data.studentUid == request.auth.uid;
      allow update: if isStaff() ||
        (signedIn() && resource.data.studentUid == request.auth.uid
                    && request.resource.data.studentUid == request.auth.uid);
      allow delete: if isStaff();
    }

    // deny everything else
    match /{document=**} { allow read, write: if false; }
  }
}
